{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KachaKache",
  "version": "0.1.1",
  "identifier": "com.sdglhm.kachakache",
  "build": {
    "beforeDevCommand": "npm run sync:whisper-runtime && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run sync:whisper-runtime && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KachaKache",
        "width": 860,
        "height": 640,
        "minWidth": 760,
        "minHeight": 620,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 24
        },
        "resizable": true,
        "visible": true
      }
    ],
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "resources/whisper"
    ],
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 980,
          "height": 654
        },
        "appPosition": {
          "x": 225,
          "y": 275
        },
        "applicationFolderPosition": {
          "x": 705,
          "y": 275
        }
      }
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
